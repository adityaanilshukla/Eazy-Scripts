#!/usr/bin/env bash
set -euo pipefail

LOG_FILE="/tmp/connect-headphones.log"
exec > >(tee "$LOG_FILE") 2>&1
echo "=== connect-headphones run at $(date -Iseconds) ==="

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.bluetooth.env"

if [[ -f "$ENV_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENV_FILE"
else
  echo "Environment file $ENV_FILE not found."
  command -v notify-send >/dev/null 2>&1 && notify-send "Headphones" "Missing .bluetooth.env file"
  exit 1
fi

have() { command -v "$1" >/dev/null 2>&1; }
bt() { bluetoothctl --timeout "${BT_SCAN_TIMEOUT:-10}" "$@"; }

notify() {
  local msg="$1"
  if have notify-send; then notify-send "Headphones" "$msg"; fi
  echo "$msg"
}

find_macs_by_name() {
  local name="$1"
  local strict="${BT_STRICT_NAME:-0}"
  local tmpfile
  tmpfile="$(mktemp)"
  trap 'rm -f "$tmpfile"' RETURN

  if [[ "$strict" -eq 1 ]]; then
    bluetoothctl devices Paired | awk -v IGNORECASE=1 -v n="$name" '
      $1=="Device" {mac=$2; $1=$2=""; sub(/^  */,""); if (tolower($0)==tolower(n)) print mac}' >>"$tmpfile"
    bluetoothctl devices | awk -v IGNORECASE=1 -v n="$name" '
      $1=="Device" {mac=$2; $1=$2=""; sub(/^  */,""); if (tolower($0)==tolower(n)) print mac}' >>"$tmpfile"
  else
    bluetoothctl devices Paired | grep -iF "$name" | awk '$1=="Device"{print $2}' >>"$tmpfile" || true
    bluetoothctl devices | grep -iF "$name" | awk '$1=="Device"{print $2}' >>"$tmpfile" || true
  fi

  awk '!seen[$0]++ {print}' "$tmpfile"
}

refresh_scan() {
  notify "Scanning to refresh device cache..."
  bluetoothctl --timeout "${BT_SCAN_TIMEOUT:-10}" scan on >/dev/null 2>&1 || true
  sleep "${BT_ACTIVE_SCAN_SECS:-6}"
  bluetoothctl scan off >/dev/null 2>&1 || true
}

disconnect_and_remove() {
  local mac="$1"
  if bluetoothctl info "$mac" 2>/dev/null | grep -q "Connected: yes"; then
    echo "Disconnecting $mac..."
    bluetoothctl disconnect "$mac" >/dev/null 2>&1 || true
    sleep 1
  fi
  echo "Removing $mac..."
  bluetoothctl remove "$mac" >/dev/null 2>&1 || true
  sleep 1
  if bluetoothctl info "$mac" >/dev/null 2>&1; then
    echo "Warning: $mac still present after remove."
    return 1
  fi
  return 0
}

is_connected() {
  local mac="$1"
  bluetoothctl info "$mac" 2>/dev/null | grep -q "Connected: yes"
}

is_paired() {
  local mac="$1"
  bluetoothctl info "$mac" 2>/dev/null | grep -q "Paired: yes"
}

pause_all_media() {
  echo "Pausing media players..."
  playerctl --all-players pause 2>/dev/null || true
}

# Try a plain reconnect against an existing pairing. Returns 0 on success.
quick_reconnect() {
  local mac="$1"
  notify "Trying quick reconnect to $mac..."
  if bluetoothctl connect "$mac" >/dev/null 2>&1; then
    sleep 2
    if is_connected "$mac"; then
      return 0
    fi
  fi
  return 1
}

# Full forget -> scan -> pair -> trust -> connect dance.
full_repair() {
  local name="$1"
  local targets=()
  mapfile -t targets < <(find_macs_by_name "$name")

  if ((${#targets[@]} > 0)); then
    echo "Forgetting: ${targets[*]}"
    for mac in "${targets[@]}"; do
      disconnect_and_remove "$mac" || true
    done
  fi

  refresh_scan

  local mac
  mac="$(find_macs_by_name "$name" | head -n1 || true)"
  if [[ -z "$mac" ]]; then
    notify "Device \"$name\" not found after scan. Is it in pairing mode?"
    return 1
  fi

  if ! is_paired "$mac"; then
    notify "Pairing with $mac..."
    bluetoothctl pair "$mac" >/dev/null || { notify "Pairing failed."; return 1; }
    sleep 1
  fi

  if ! bluetoothctl info "$mac" 2>/dev/null | grep -q "Trusted: yes"; then
    notify "Trusting $mac..."
    bluetoothctl trust "$mac" >/dev/null || { notify "Trust failed."; return 1; }
    sleep 1
  fi

  notify "Connecting to $mac..."
  if bluetoothctl connect "$mac" >/dev/null 2>&1; then
    sleep 2
    if is_connected "$mac"; then
      echo "$mac"
      return 0
    fi
  fi
  notify "Connection failed for $mac."
  return 1
}

# Wait for the bluez_card.<MAC> entry to appear in PipeWire (PulseAudio compat).
wait_for_card() {
  local card="$1"
  local tries="${2:-20}"  # ~10s at 0.5s each
  for ((i=0; i<tries; i++)); do
    if pactl list cards short 2>/dev/null | awk '{print $2}' | grep -qx "$card"; then
      return 0
    fi
    sleep 0.5
  done
  return 1
}

# Pick a profile name starting with a2dp-sink (codec suffixes vary across stacks).
# Profile entries live under a "Profiles:" heading and are indented with two tabs.
pick_a2dp_profile() {
  local card="$1"
  pactl list cards 2>/dev/null | awk -v c="$card" '
    /^Card #/ {incard=0; inprof=0}
    $1=="Name:" && $2==c {incard=1; next}
    incard && /^\tProfiles:/ {inprof=1; next}
    incard && inprof && /^\t[^\t]/ {inprof=0}
    incard && inprof && /^\t\t[A-Za-z0-9._-]+:/ {
      sub(/^\t\t/, "")
      sub(/:.*$/, "")
      print
    }
  ' | awk '
    /^a2dp-sink$/ {exact=$0}
    /^a2dp-sink/ {if (!any) any=$0}
    END {print (exact ? exact : any)}
  '
}

activate_audio_profile() {
  local mac="$1"
  local card="bluez_card.${mac//:/_}"

  if ! wait_for_card "$card"; then
    notify "PipeWire card $card never appeared; audio not activated."
    return 1
  fi

  local profile
  profile="$(pick_a2dp_profile "$card" || true)"
  if [[ -z "$profile" ]]; then
    notify "No a2dp-sink profile available on $card."
    return 1
  fi

  if ! pactl set-card-profile "$card" "$profile" 2>/dev/null; then
    notify "Failed to set profile $profile on $card."
    return 1
  fi

  # Sink name is derived from the MAC; the exact suffix depends on the stack.
  local sink
  sink="$(pactl list sinks short 2>/dev/null | awk '{print $2}' | grep -F "${mac//:/_}" | head -n1 || true)"
  if [[ -z "$sink" ]]; then
    # Give PipeWire a beat to register the sink after profile switch.
    sleep 1
    sink="$(pactl list sinks short 2>/dev/null | awk '{print $2}' | grep -F "${mac//:/_}" | head -n1 || true)"
  fi

  if [[ -z "$sink" ]]; then
    notify "Profile $profile set, but no bluez sink found yet."
    return 1
  fi

  pactl set-default-sink "$sink" 2>/dev/null || true

  # Move any existing streams onto the new sink so audio routes immediately.
  while read -r id _; do
    [[ -n "$id" ]] && pactl move-sink-input "$id" "$sink" 2>/dev/null || true
  done < <(pactl list short sink-inputs 2>/dev/null)

  notify "Audio routed to $sink ($profile)."
  return 0
}

main() {
  if [[ -z "${BT_HEADPHONES_NAME:-}" ]]; then
    notify "BT_HEADPHONES_NAME not set in .bluetooth.env."
    exit 1
  fi

  pause_all_media

  local mac=""
  local connected_via=""

  # Smart path: is there already a paired entry we can reconnect to?
  mac="$(find_macs_by_name "$BT_HEADPHONES_NAME" | head -n1 || true)"

  if [[ -n "$mac" ]] && is_connected "$mac"; then
    notify "Already connected to $mac."
    connected_via="$mac"
  elif [[ -n "$mac" ]] && is_paired "$mac" && quick_reconnect "$mac"; then
    notify "Reconnected to $mac."
    connected_via="$mac"
  else
    notify "Quick reconnect unavailable; running full re-pair flow."
    if mac="$(full_repair "$BT_HEADPHONES_NAME")"; then
      connected_via="$mac"
    else
      exit 1
    fi
  fi

  if ! activate_audio_profile "$connected_via"; then
    exit 1
  fi

  exit 0
}

main "$@"
